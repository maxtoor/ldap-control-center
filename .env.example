# New LDAP (target)
LDAP_HOST=openldap
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_ADMIN_DN=cn=admin,dc=example,dc=org
LDAP_ADMIN_PASSWORD=admin
LDAP_USERS_BASE_DN=ou=users,dc=example,dc=org
LDAP_GROUPS_BASE_DN=ou=groups,dc=example,dc=org
LDAP_DEFAULT_OBJECT_CLASSES=inetOrgPerson,organizationalPerson,person,top
APP_TITLE=LDAP Control Center
APP_SUBTITLE=Gestione utenti su OpenLDAP
APP_COMPANY=Emilio Paolo Castelluccio
APP_LOGO_URL=
APP_LOGO_LINK=/
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin
APP_SESSION_SECRET=change-this-session-secret
APP_SESSION_TTL_HOURS=12
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_BASE_URL=http://localhost:8000
PASSWORD_RESET_SHOW_LINK=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LDAP Control Center
SMTP_RESET_SUBJECT=Reset password account LDAP
UPDATE_NOTIFY_EMAIL=

# Legacy LDAP (source, used by migration script)
LEGACY_LDAP_HOST=legacy-ldap.example.org
LEGACY_LDAP_PORT=389
LEGACY_LDAP_USE_SSL=false
LEGACY_LDAP_BIND_DN=cn=admin,dc=old,dc=example,dc=org
LEGACY_LDAP_BIND_PASSWORD=change-me
LEGACY_LDAP_USERS_BASE_DN=ou=users,dc=old,dc=example,dc=org
LEGACY_LDAP_GROUPS_BASE_DN=ou=groups,dc=old,dc=example,dc=org
